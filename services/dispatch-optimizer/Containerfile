# This project was developed with assistance from AI tools.
FROM registry.access.redhat.com/ubi9/python-312:latest

WORKDIR /opt/app-root/src

USER 0
COPY services/common/ /tmp/common/
RUN pip install --no-cache-dir /tmp/common/ && rm -rf /tmp/common/
USER 1001
COPY services/dispatch-optimizer/dispatch_optimizer/ dispatch_optimizer/
COPY services/dispatch-optimizer/pyproject.toml .

RUN pip install --no-cache-dir .

EXPOSE 8080

CMD ["uvicorn", "dispatch_optimizer.app:app", "--host", "0.0.0.0", "--port", "8080"]
